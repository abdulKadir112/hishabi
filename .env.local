# লোকাল ডেভেলপমেন্টের জন্য (আপনার কম্পিউটারে backend চালু থাকলে)
NEXT_PUBLIC_API_URL=http://localhost:5000

# যদি Vercel-এর deployed backend টেস্ট করতে চান তাহলে এটা uncomment করুন
NEXT_PUBLIC_API_URL=https://hishabi-api.vercel.app

# অতিরিক্ত (optional) — যদি অন্য কোনো variable লাগে
# NEXT_PUBLIC_APP_NAME=হিসাবী